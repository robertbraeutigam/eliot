<idea-plugin>
    <id>com.vanillasource.eliot.intellij</id>
    <name>Eliot</name>
    <vendor email="brautigam.robert.gyula@gmail.com" url="https://github.com/vanillasource">VanillaSource</vendor>

    <description><![CDATA[
        Support for the <b>Eliot</b> programming language (<code>.els</code>):
        <ul>
            <li>Syntax highlighting via a bundled TextMate grammar.</li>
            <li>Diagnostics (errors/warnings) provided by the Eliot language server, run through LSP4IJ.</li>
            <li>Doc/block-comment continuation: pressing Enter inside a <code>/** ... */</code> comment keeps the aligned <code>*</code> prefix, as in Java/Scala.</li>
        </ul>
        The language server is bundled with the plugin; no separate installation or build file is needed —
        the open project folder is the workspace, and the Eliot standard library travels inside the plugin.
    ]]></description>

    <!-- Platform + LSP4IJ are required. TextMate is bundled in every IDE; depended on optionally so the
         language server still works if a user has disabled the TextMate plugin (only highlighting is lost). -->
    <depends>com.intellij.modules.platform</depends>
    <!-- modules.lang owns the enterHandlerDelegate extension point (comment continuation); present in every
         IntelliJ-based IDE. -->
    <depends>com.intellij.modules.lang</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>
    <depends optional="true" config-file="eliot-textmate.xml">org.jetbrains.plugins.textmate</depends>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="eliot"
                name="Eliot Language Server"
                factoryClass="com.vanillasource.eliot.intellij.EliotLanguageServerFactory">
            <description><![CDATA[Eliot language server — whole-workspace diagnostics for <code>.els</code> files.]]></description>
        </server>
        <!-- Pattern mapping (rather than a Language/FileType mapping) so the TextMate grammar keeps
             owning syntax coloration while LSP4IJ provides language features for the same files. -->
        <fileNamePatternMapping patterns="*.els" serverId="eliot" languageId="eliot"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Native "Eliot Application" run configuration: builds a `main` into an executable jar and runs it. -->
        <configurationType implementation="com.vanillasource.eliot.intellij.run.EliotRunConfigurationType"/>
        <!-- The build-the-jar step attached before the run (compiler CLI off the bundled server+compiler jars). -->
        <stepsBeforeRunProvider implementation="com.vanillasource.eliot.intellij.run.EliotBuildBeforeRunTaskProvider"/>
        <!-- Surfaces compiler errors when the before-run build fails. -->
        <notificationGroup id="Eliot" displayType="BALLOON"/>
        <!-- Continues `/** */`/`/* */` comments with an aligned ` * ` on Enter (Java/Scala-style), client-side.
             Global EP; the handler self-selects .els files (which have no registered Language, only TextMate). -->
        <enterHandlerDelegate implementation="com.vanillasource.eliot.intellij.EliotCommentEnterHandler"/>
    </extensions>

    <actions>
        <!-- The id MUST equal the LSP code-lens command ("eliot.runMain"): LSP4IJ dispatches a code-lens
             command client-side via ActionManager.getAction(commandId). -->
        <action id="eliot.runMain"
                class="com.vanillasource.eliot.intellij.run.EliotRunMainCommandAction"
                text="Run Eliot Main"
                description="Build and run the Eliot main reported by the language server."/>
    </actions>
</idea-plugin>
