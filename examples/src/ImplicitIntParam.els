import eliot.effect.Console
/**
 * Inferred generic inputs. The bare `Int` parameter of `describe` is generalized: its omitted bounds become
 * inferred generic parameters, so `describe` accepts any integer width and recovers the bounds from each call's
 * argument. `describe(42)` instantiates it at `Int[42, 42]`. Prints `42`.
 */
def describe(x: Int): String = intToString(x)

def main: IO[Unit] = println(describe(42))
