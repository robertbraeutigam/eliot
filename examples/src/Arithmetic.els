import eliot.effect.Console
import eliot.lang.Numeric
/**
 * Integer arithmetic. Every integer is a plain `Int` (a value's range is meta-information in the refinement channel),
 * and `+`/`-`/`*` compute over it, with `*` binding tighter than `+`/`-`. Prints `14`.
 */
def main: IO[Unit] = printLine(intToString(2 + 3 * 4))
