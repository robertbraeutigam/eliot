import eliot.effect.Console
/**
 * Inferred generic data fields. The bare `Int` field of `Counter` is generalized: its omitted bounds become
 * generic parameters of the data type. `Counter(42)` yields `Counter[42, 42]`, and the accessor `n` recovers
 * the field as `Int[42, 42]`. Prints `42`.
 */
data Counter(n: Int)

def main: IO[Unit] = printLine(intToString(Counter(42).n))
