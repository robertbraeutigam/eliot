import eliot.effect.Console
/**
 * An `Int` data field. `Int` is a single type (a value's range is meta-information in the refinement channel, not a type
 * parameter), so `Counter` has no type parameters; `Counter(42).n` recovers the field. Prints `42`.
 */
data Counter(n: Int)

def main: {Console} Unit = printLine(show(Counter(42).n))
