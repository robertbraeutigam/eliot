import eliot.effect.Console
import eliot.lang.Numeric

def sum(x: Int, y: Int): Int = add(x, y)
def diff(x: Int, y: Int): Int = subtract(x, y)
def prod(x: Int, y: Int): Int = multiply(x, y)

// Nested calls to the same homogeneous ability method: `add`/`subtract`/`multiply` over plain `Int`.

def main: IO[Unit] = printLine(intToString(add(sum(30, 20), add(diff(40, 10), prod(3, 4)))))
