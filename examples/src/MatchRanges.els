
data Choice = First | Second

// A `match` whose arms return different integer literals. Which arm runs is only known at run time, so the result is a
// plain `Int` (the arms' value ranges are meta-information in the refinement channel, no longer distinct types that must
// be joined). Prints `5`.
def choose(c: Choice): Int = c match {
  case First  -> 5
  case Second -> 15
}

def main: {Console} Unit = printLine(show(choose(First)))
