import eliot.lang.Effect
import eliot.lang.Sync
import eliot.lang.Abort
import eliot.lang.State
import eliot.lang.Option

/**
 * The internal carrier that realises the `Abort` effect: an `OptionT[G, A]` is a `G`-computation producing an
 * `Option[A]` â€” `Some(a)`, or `None` if it short-circuited.
 *
 * Plumbing only â€” application code never imports or names it. A function that may short-circuit declares `{Abort}` and
 * discharges it with `runAbort`/`orElse` (in `eliot.lang.Abort`); this carrier is what those operate on under the hood.
 * Generic over the base carrier `G`, so it composes over `IO`, `OptionT[IO]`, and so on.
 */
data OptionT[G[_], A](runOptionT: G[Option[A]])

/**
 * `OptionT` is an effect carrier whenever its base `G` is: `pure` injects via `G`'s `pure` and a `Some`; `flatMap` runs
 * the inner `G[Option[A]]`, and on `Some(a)` continues with `f`, on `None` short-circuits (the `Abort` semantics); `map`
 * transforms a present value and propagates `None`, given directly so it needs no `pure` round-trip. The author-written
 * `pure(None)` stays put â€” the effect-desugar phase does not bind an explicit machinery call.
 */
implement[G[_] ~ Effect] Effect[OptionT[G]] {
   def pure[A](a: A): OptionT[G, A] = OptionT(pure(Some(a)))
   def flatMap[A, B](fa: OptionT[G, A], f: Function[A, OptionT[G, B]]): OptionT[G, B] =
      OptionT(flatMap(runOptionT(fa), o -> foldOption(o, pure(None), a -> runOptionT(f(a)))))
   def map[A, B](fa: OptionT[G, A], f: Function[A, B]): OptionT[G, B] =
      OptionT(map(runOptionT(fa), o -> foldOption(o, None, a -> Some(f(a)))))
}

/**
 * The base-effect lift: `OptionT[G]` is `Sync` whenever `G` is, by running the inner sync action and wrapping its result
 * in `Some`. This single per-transformer lift is what carries every `Sync`-keyed fine effect (`Console`, `Log`, â€¦)
 * through the `OptionT` layer for free.
 */
implement[G[_] ~ Sync & Effect] Sync[OptionT[G]] {
   def sync[A](thunk: Function[Unit, A]): OptionT[G, A] = OptionT(map(sync(thunk), a -> Some(a)))
}

/**
 * The `Abort` instance: `abort` is the short-circuit â€” an `OptionT` whose inner computation purely yields `None`.
 */
implement[G[_] ~ Effect] Abort[OptionT[G]] {
   def abort[A]: OptionT[G, A] = OptionT(pure(None))
}

/**
 * Cross-lift: `State[S]` rides through the `OptionT` layer (one cell of the nÂ˛ mtl lifting matrix). When a
 * `{State[S], Abort}` program discharges `Abort` *first* (`runState(runAbort(p), s0)`), the carrier is refined to
 * `OptionT[G]` with `G` still carrying `State`, so the residual `getState`/`putState` must run at `OptionT[G]`. They
 * delegate to the inner `G`'s state and wrap the result in `Some` â€” state is never *absent* here; only the eventual
 * `abort` makes the discharged *value* `None`. Because `OptionT` sits *outside* the (inner) `StateT`, the threaded
 * state survives an abort: discharging in this order yields `Pair[Option[A], S]`. Its order-sensitive counterpart is
 * `Abort[StateT[S, G]]` (in `StateT`).
 */
implement[S, G[_] ~ State[S] & Effect] State[S, OptionT[G]] {
   def getState: OptionT[G, S] = OptionT(map(getState, s -> Some(s)))
   def putState(newS: S): OptionT[G, Unit] = OptionT(map(putState(newS), u -> Some(u)))
}
