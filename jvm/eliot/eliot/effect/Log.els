import eliot.effect.Sync

ability Log[F[_]] {
   def log(s: String): F[Unit]
}

/**
 * The JVM `Log` instance, generic over any carrier with a `Sync` base (never pinned to `IO`): it reifies a `private`
 * impure leaf native through `sync`, exactly like `Console`. Because it rides `Sync`, the same instance serves `IO`,
 * `AbortCarrier[IO]`, etc.; the whole `IO(_ -> ...)` tree stays Eliot-visible to monomorphization, only the leaf is opaque.
 */
implement[F[_] ~ Sync] Log[F] {
   def log(s: String): F[Unit] = sync(_ -> logInternal(s))
}

/**
 * The single impure operation behind `log`: writes a diagnostic line to standard output. `private` so user
 * code reaches logging only through the `{Log}`-typed `log`. Implemented by the backend.
 */
private def logInternal(s: String): Unit
