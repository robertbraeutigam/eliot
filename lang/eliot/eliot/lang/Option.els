/**
 * An optional value: either present or absent.
 *
 * Models a value that may be missing without resorting to a sentinel or an error — `some(x)` holds a
 * present value and `none` marks its absence.
 */
type Option[A]

/**
 * The present case of `Option`, holding a value of type `A`.
 */
def some[A](value: A): Option[A]
