/**
 * A function from a single argument of type `A` to a result of type `B`. Lambdas have this type.
 *
 * Multi-argument functions are represented in curried form — `A -> B -> C` is
 * `Function[A, Function[B, C]]` — so applying one argument yields the function that takes the next.
 */
type Function[A, B]

/**
 * Apply a function to its argument: `apply(f, a)` is `f(a)`.
 */
def apply[A, B](f: Function[A, B], a: A): B = f(a)
