/**
 * The logging effect: emitting diagnostic messages.
 *
 * Can be used in any context, even in otherwise pure functions to
 * emit the usual log messages. This is a purposefully minimal
 * api and is expected to be wrapped by a more powerful one on
 * a specific platform.
 */
ability Log[F[_]] {
   /**
    * Emit a diagnostic message; the platform chooses the destination.
    */
   def log(s: String): F[Unit]
}
