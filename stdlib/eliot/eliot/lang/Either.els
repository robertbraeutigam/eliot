/**
 * The result of a computation that may fail: `Left(error)` for failure, `Right(value)` for success.
 *
 * By convention the error sits in `Left` and the successful result in `Right`. It is what the
 * `Throw[E]` effect discharges into via `runThrow`: running a `{Throw[E]}` computation yields a
 * `Right` holding its result or a `Left` holding the error that was raised. Consume one with `foldEither`.
 */
type Either[E, A]
