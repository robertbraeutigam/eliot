/**
 * The logging effect: emitting diagnostic messages.
 *
 * A fine-grained effect alongside `Console` — declare `{Log}` and call `log`. Like the other I/O
 * effects it runs on any carrier with a `Sync` base, and combines freely with other effects in one
 * signature, e.g. `{Dep[Database], Log, Console}`.
 */
ability Log[F[_]] {
   /**
    * Emit a diagnostic message; the platform chooses the destination.
    */
   def log(s: String): F[Unit]
}
