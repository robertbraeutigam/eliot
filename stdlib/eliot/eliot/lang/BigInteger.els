import eliot.lang.Numeric
import eliot.lang.Compare
import eliot.lang.Bool

type BigInteger

implement Numeric[BigInteger] {
   def add(a: BigInteger, b: BigInteger): BigInteger
   def subtract(a: BigInteger, b: BigInteger): BigInteger
   def multiply(a: BigInteger, b: BigInteger): BigInteger
}

implement Compare[BigInteger] {
   def lessThanOrEqual(a: BigInteger, b: BigInteger): Bool
}
