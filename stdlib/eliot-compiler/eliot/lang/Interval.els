import eliot.lang.Numeric
import eliot.lang.Compare
import eliot.compiler.Meta

/**
 * The compile-time `Interval`: the compiler platform's self-sufficient copy of the representation and the domain
 * instance bodies (the bodies are pure â€” endpoint-wise delegation to the endpoints' own `Numeric`/`Compare` â€” so the
 * same Eliot code runs under the compiler's NbE evaluator). Self-sufficiency is the point: a compile-time interval
 * (e.g. as an `Int` bound object) must not depend on a sibling *runtime* target's layer being present.
 *
 * Only the refinement-domain pieces live here (`Meta[Interval[T, T]]` for joins; the plain `intervalAdd`/`intervalSubtract`/
 * `intervalMultiply` transfer functions the `Int` `^Meta` vessels reach) â€” the ones the bounds-as-refinements channel
 * evaluates. The runtime `Arithmetic[Interval, Interval]` instance (with its associated-type result formulas) stays
 * split across the base + jvm layers; the compiler track no longer needs it, so it is not copied into this overlay
 * (`docs/bounds-as-refinements.md` Step 5).
 */
data Interval[S, E](start: S, end: E)

/**
 * A same-endpoint `Interval[T, T]` (e.g. `Interval[BigInteger, BigInteger]`, an `Int`'s value range) is a refinement
 * **domain** â€” the value a range is tracked as by the bounds-as-refinements channel
 * (`docs/bounds-as-refinements.md`). Its lattice `join` covers two ranges: the least interval containing both is
 * `[min of the starts, max of the ends]`, delegating to the endpoints' own `Compare` â€” the value-level twin of the
 * type-level `Combine[Int, Int]` join the channel is migrating off. A compiler-pool-only instance, exercised in shadow
 * mode at `match`/`if` branch merges.
 */
implement[T ~ Compare[T]] Meta[Interval[T, T]] {
   def join(a: Interval[T, T], b: Interval[T, T]): Interval[T, T] =
      Interval(min(start(a), start(b)), max(end(a), end(b)))
}

/**
 * A same-endpoint `Interval[T, T]` closes under arithmetic â€” the single-parameter, non-associated-type transfer the
 * refinement channel evaluates (`docs/bounds-as-refinements.md` Step 4c). These are **plain functions**, not a
 * `Numeric[Interval]` ability instance: an `Int`'s `^Meta` transfer companion reaches them *transitively* (through the
 * vessel's return brace), and a transitively-reached Eliot-body ability *instance* does not dispatch under the channel's
 * NbE evaluation â€” only natives re-fire transitively â€” so the interval arithmetic must bottom out directly at the
 * endpoints' `Numeric` **natives** (and, for multiplication's corner selection, `Compare`). Because both endpoints share
 * one type `T`, every result endpoint is again a `T`, so each is a plain `Interval[T, T] -> Interval[T, T] ->
 * Interval[T, T]` with no `AddResult`/`SubResult`/`MulResult` formulas or corner annotations.
 *
 *   - `[a, b] + [c, d] = [a + c, b + d]`
 *   - `[a, b] - [c, d] = [a - d, b - c]`   (subtraction pairs a start with the other end)
 *   - `[a, b] * [c, d] = [min of the four corner products, max of them]`
 *
 * At the `Int` domain (`T = BigInteger`) `add`/`subtract`/`multiply` reduce through the `Numeric[BigInteger]` compile-time
 * leaves. The bare `add`/`subtract`/`multiply` resolve unambiguously here (this overlay imports only `Numeric`, not
 * `Arithmetic`).
 */
def intervalAdd[T ~ Numeric](a: Interval[T, T], b: Interval[T, T]): Interval[T, T] =
   Interval(add(start(a), start(b)), add(end(a), end(b)))
def intervalSubtract[T ~ Numeric](a: Interval[T, T], b: Interval[T, T]): Interval[T, T] =
   Interval(subtract(start(a), end(b)), subtract(end(a), start(b)))
def intervalMultiply[T ~ Numeric & Compare](a: Interval[T, T], b: Interval[T, T]): Interval[T, T] = {
   val c11 = multiply(start(a), start(b))
   val c12 = multiply(start(a), end(b))
   val c21 = multiply(end(a), start(b))
   val c22 = multiply(end(a), end(b))
   Interval(min(min(min(c11, c12), c21), c22), max(max(max(c11, c12), c21), c22))
}
