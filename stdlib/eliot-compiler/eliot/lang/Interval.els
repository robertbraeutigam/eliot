import eliot.lang.Numeric
import eliot.lang.Compare
import eliot.lang.Bool
import eliot.compiler.Meta

/**
 * The compile-time `Interval`: the compiler platform's self-sufficient copy of the representation and the domain
 * instance bodies (the bodies are pure — endpoint-wise delegation to the endpoints' own `Numeric`/`Compare` — so the
 * same Eliot code runs under the compiler's NbE evaluator). Self-sufficiency is the point: a compile-time interval
 * (e.g. as an `Int` bound object) must not depend on a sibling *runtime* target's layer being present.
 *
 * Only the refinement-domain pieces live here (`Meta[Interval[T]]` for joins; the plain `intervalAdd`/`intervalSubtract`/
 * `intervalMultiply` transfer functions the `Int` `^Meta` vessels reach) — the ones the bounds-as-refinements channel
 * evaluates. The runtime `Numeric[Interval[T]]` instance stays split across the base + jvm layers; the compiler track
 * reaches the transfer through the plain functions below (a transitively-reached ability *instance* does not dispatch
 * under the channel's NbE evaluation), so the instance is not copied into this overlay.
 */
data Interval[T](start: T, end: T)

/**
 * An `Interval[T]` (e.g. `Interval[BigInteger]`, an `Int`'s value range) is a refinement **domain** — the value a range
 * is tracked as by the bounds-as-refinements channel (`docs/bounds-as-refinements.md`). Its lattice `join` covers two
 * ranges: the least interval containing both is `[min of the starts, max of the ends]`, delegating to the endpoints' own
 * `Compare`. A compiler-pool-only instance, exercised at `match`/`if` branch merges.
 */
implement[T ~ Compare[T]] Meta[Interval[T]] {
   def join(a: Interval[T], b: Interval[T]): Interval[T] =
      Interval(min(start(a), start(b)), max(end(a), end(b)))
}

/**
 * An `Interval[T]` closes under arithmetic — the non-associated-type transfer the refinement channel evaluates
 * (`docs/bounds-as-refinements.md` Step 4c). These are **plain functions**, not a `Numeric[Interval]` ability instance:
 * an `Int`'s `^Meta` transfer companion reaches them *transitively* (through the vessel's return brace), and a
 * transitively-reached Eliot-body ability *instance* does not dispatch under the channel's NbE evaluation — only natives
 * re-fire transitively — so the interval arithmetic must bottom out directly at the endpoints' `Numeric` **natives** (and,
 * for multiplication's corner selection, `Compare`).
 *
 *   - `[a, b] + [c, d] = [a + c, b + d]`
 *   - `[a, b] - [c, d] = [a - d, b - c]`   (subtraction pairs a start with the other end)
 *   - `[a, b] * [c, d] = [min of the four corner products, max of them]`
 *
 * At the `Int` domain (`T = BigInteger`) `add`/`subtract`/`multiply` reduce through the `Numeric[BigInteger]` compile-time
 * leaves. The bare `add`/`subtract`/`multiply` resolve unambiguously here (this overlay imports only `Numeric`, not
 * `Arithmetic`).
 */
/**
 * True iff the interval `i` fits a signed byte — the width-named `where` precondition predicate for an `Int`'s tracked
 * range: `def useByte(x: Int): Int where withinByte(range(x))` demands, at each call, that the caller's computed range
 * for `x` fits a signed byte, reducing to a `Bool` over the argument's concrete interval. It bakes the width bounds
 * (from `BigInteger`'s `fitsByte`), so a `where` needs no `BigInteger` literals. Compiler-pool-only (the channel
 * evaluates it), like the interval arithmetic above.
 */
def withinByte(i: Interval[BigInteger]): Bool = fitsByte(start(i), end(i))

/**
 * The lattice join of two intervals — the least interval containing both, `[min of the starts, max of the ends]`. The
 * **plain-function** form of the `Meta[Interval[T]]` instance's `join` (they compute the same thing): the compiler's
 * auto-derived `Meta[T$Meta]` instances reach it *transitively* through their generated bodies, and a transitively-
 * reached ability *instance* does not dispatch under the refinement channel's NbE evaluation — only natives re-fire — so
 * a compound meta-structure's join must bottom out at this plain function (which itself bottoms at the endpoints'
 * `Compare` natives), exactly as `intervalAdd`/… back the arithmetic transfer (`docs/generic-refinement-merges.md`).
 */
def intervalJoin[T ~ Compare](a: Interval[T], b: Interval[T]): Interval[T] =
   Interval(min(start(a), start(b)), max(end(a), end(b)))

def intervalAdd[T ~ Numeric](a: Interval[T], b: Interval[T]): Interval[T] =
   Interval(add(start(a), start(b)), add(end(a), end(b)))
def intervalSubtract[T ~ Numeric](a: Interval[T], b: Interval[T]): Interval[T] =
   Interval(subtract(start(a), end(b)), subtract(end(a), start(b)))
def intervalMultiply[T ~ Numeric & Compare](a: Interval[T], b: Interval[T]): Interval[T] = {
   val c11 = multiply(start(a), start(b))
   val c12 = multiply(start(a), end(b))
   val c21 = multiply(end(a), start(b))
   val c22 = multiply(end(a), end(b))
   Interval(min(min(min(c11, c12), c21), c22), max(max(max(c11, c12), c21), c22))
}
